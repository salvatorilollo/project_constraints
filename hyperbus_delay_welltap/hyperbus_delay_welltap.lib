library (hyperbus_delay_welltap) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1mA";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 25.0;
  nom_voltage                    : 1.20;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00100,  0.00400,  0.02000,  0.04000,  0.08000,  0.13200,  0.20000");
  }
  type ("delay_i") {
    base_type : array;
    data_type : bit;
    bit_width : 8;
    bit_from : 7;
    bit_to : 0;
  }

  cell ("hyperbus_delay_welltap") {
    area : 1082.391 
    is_macro_cell : true;
    pin("in_i") {
      direction : input;
      capacitance : 0.0092;
    }
    pin("out_o") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "in_i";
        timing_sense : positive_unate;
        timing_type : combinational;
        cell_rise(template_1) {
          index_1("0.00100,  0.00400,  0.02000,  0.04000,  0.08000,  0.13200,  0.20000");
          values("1.54993,1.56705,1.62672,1.69132,1.81806,1.98225,2.19685");
        }
        rise_transition(template_1) {
          index_1("0.00100,  0.00400,  0.02000,  0.04000,  0.08000,  0.13200,  0.20000");
          values("0.03232,0.04477,0.11090,0.19928,0.38090,0.61862,0.92996");
        }
        cell_fall(template_1) {
          index_1("0.00100,  0.00400,  0.02000,  0.04000,  0.08000,  0.13200,  0.20000");
          values("1.70232,1.71822,1.77282,1.82803,1.93312,2.06808,2.24409");
        }
        fall_transition(template_1) {
          index_1("0.00100,  0.00400,  0.02000,  0.04000,  0.08000,  0.13200,  0.20000");
          values("0.03163,0.04284,0.09534,0.16186,0.29938,0.48107,0.71957");
        }
      }
    }
    bus("delay_i") {
      bus_type : delay_i;
      direction : input;
      capacitance : 0.0000;
    pin("delay_i[7]") {
      direction : input;
      capacitance : 0.0000;
    }
    pin("delay_i[6]") {
      direction : input;
      capacitance : 0.0057;
    }
    pin("delay_i[5]") {
      direction : input;
      capacitance : 0.0096;
    }
    pin("delay_i[4]") {
      direction : input;
      capacitance : 0.0200;
    }
    pin("delay_i[3]") {
      direction : input;
      capacitance : 0.0116;
    }
    pin("delay_i[2]") {
      direction : input;
      capacitance : 0.0144;
    }
    pin("delay_i[1]") {
      direction : input;
      capacitance : 0.0043;
    }
    pin("delay_i[0]") {
      direction : input;
      capacitance : 0.0049;
    }
    }
    pin("VSS") {
      direction : inout;
      capacitance : 0.0000;
    }
    pin("VDD") {
      direction : inout;
      capacitance : 0.0000;
    }
  }

}
