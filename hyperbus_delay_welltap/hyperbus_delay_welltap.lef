MACRO AND2X1
    CLASS CORE ;
    SIZE 2.1 BY 3.36 ;
    SYMMETRY X Y ;
    SITE CoreSite ;
    PIN VSS
        DIRECTION INOUT ; 
        USE GROUND ; 
        PORT
            LAYER Metal1 ;
              RECT  0 -0.16 2.1 0.16 ;
              RECT  1.195 -0.16 1.355 0.62 ;
        END
    END VSS
    PIN VDD
        DIRECTION INOUT ; 
        USE POWER ; 
        PORT
            LAYER Metal1 ;
              RECT  0 3.2 2.1 3.52 ;
              RECT  1.195 2.74 1.355 3.52 ;
              RECT  0.175 2.74 0.335 3.52 ;
        END
    END VDD
    PIN B
        DIRECTION INPUT ; 
        USE SIGNAL ; 
        ANTENNAGATEAREA 0.1014 LAYER Metal1 ;
        PORT
            LAYER Metal1 ;
              RECT  1.025 1.955 1.575 2.255 ;
        END
    END B
    PIN A
        DIRECTION INPUT ; 
        USE SIGNAL ; 
        ANTENNAGATEAREA 0.1014 LAYER Metal1 ;
        PORT
            LAYER Metal1 ;
              RECT  0.105 1.535 0.505 1.835 ;
        END
    END A
    PIN Y
        DIRECTION OUTPUT ; 
        USE SIGNAL ; 
        ANTENNADIFFAREA 0.312 LAYER Metal1 ;
        PORT
            LAYER Metal1 ;
              RECT  1.755 1.535 1.995 1.825 ;
              RECT  1.755 0.36 1.99 3 ;
        END
    END Y
    OBS
      LAYER Metal1 ;
        RECT  0.685 0.91 0.845 3 ;
        RECT  0.685 1.355 1.51 1.655 ;
        RECT  0.175 0.91 0.845 1.07 ;
        RECT  0.175 0.36 0.335 1.07 ;
    END
END AND2X1

